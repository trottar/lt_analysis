################################################################################
# Use this file to define function forms of separated xsect.
# Used '#' to comment, but using '#' trailing a definition won't work
# (e.g., wfactor = 1 / ((ww**2) - (mtar**2))**2.0 # This will not work now)
################################################################################

# Define constants
pi = math.pi
mtar = 0.93827231
mpipl=0.139570
mkpl=0.493677

# 0th iteration, 
#tav = (0.1112 + 0.0066 * math.log(q2_set)) * q2_set
# Determined from (tmin, Q2) = [(0.145, 2.115), (0.17, 3.0), (0.3, 4.4), (0.35, 5.5)]
# 2nd iteration, 
tav = (0.05032 + 0.01345 * math.log(q2_set)) * q2_set
ftav = (math.fabs(tt) - tav) / tav
ft = math.fabs(tt) / (math.fabs(tt) + mkpl**2)**2  
# pole factor
Qdep_L = qq / (1.0 + (1.77 * qq) + 0.12 * (qq**2))
Qdep_T = (math.exp(-qq**2)) / qq
Qdep_TT = qq * math.exp(-qq)

# Longitudinal cross-section
# Fpi2
#sig_L = (350 * (qq) / (1 + 1.77*qq + 0.05*(qq**2))**2) * math.exp((16 - 7.5*math.log(qq))*tt)
sig_L = (par1 * (qq) / (1 + par2*qq + 0.05*(qq**2))**2) * math.exp((par3 - par4*math.log(qq))*tt)
#####
##sig_L = (par1 * ft) * math.exp(-math.fabs(par2 * tt))
#####

# Transverse cross-section
# Fpi2
#sig_T = (4.5 / qq) + (2.0 / (qq**2))
sig_T = (par5 / qq) + (par6 / (qq**2))
#####
##sig_T = (par5 / math.fabs(tt)**par6) * math.exp(-math.fabs(par7 * tt))
#####

# Longitudinal-Transverse interference term
# Fpi2
#sig_LT = (math.exp(0.79 + (3.4 / math.sqrt(qq))*tt) + 1.1 - (3.6 / (qq**2))) * math.sin(theta_cm)
sig_LT = (math.exp(par9 + (par10 / math.sqrt(qq))*tt) + par11 - (par12 / (qq**2))) * math.sin(theta_cm)
#####
##sig_LT = (par9 / math.fabs(tt))
#####

# Transverse-Transverse interference term
# Fpi2
#sig_TT = (-5.0 / (qq**2)) * (math.fabs(tt) / ((math.fabs(tt) + (mpipl**2))**2)) * (math.sin(theta_cm)**2)
sig_TT = (par13 / (qq**2)) * (math.fabs(tt) / ((math.fabs(tt) + (mpipl**2))**2)) * (math.sin(theta_cm)**2)
#####
##sig_TT = (par13 / math.fabs(tt)**par14) * math.exp(-math.fabs(par15 * tt))
#####

# Weight factor
# Fpi2
wfactor = 1 / ((ww**2) - (mtar**2))**2.0
####
